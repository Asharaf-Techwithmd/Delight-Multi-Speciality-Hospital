@{
    ViewBag.Title = "RegisterRecords";
    Layout = "~/Views/Shared/AdminZone.cshtml";
}

@using System.Data;
@using System.Data.SqlClient;
@using ArcaneClinic.Models;

<div class="container" style="box-shadow:5px 5px 10px 5px gray; margin-top:2%;">
    <div class="row">
        <div class="col-12">
            <br />
            <h2 class="text-center" style="color:darkorange; font-weight:bolder;"> Registration Records</h2>
            <hr />
        </div>

        <!-- Responsive Table -->
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead>
                        <tr>
                            <th>S.NO</th>                           
                            <th>Name</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Password</th>
                            <th>DOB</th>
                            <th>Gender</th>
                            <th>Picture</th>
                            <th>Date</th>

                        </tr>
                    </thead>
                    <tbody>
                        @{
                            string query = "select * from Register where status='yes'";
                            DataTable dtl = DatabaseManager.Display_All_Records(query);
                            if (dtl.Rows.Count > 0)
                            {
                                for (int i = 0; i < dtl.Rows.Count; i++)
                                {
                                    <tr>
                                        <td>@dtl.Rows[i]["rid"]</td>                                     
                                        <td>@dtl.Rows[i]["name"]</td>
                                        <td>@dtl.Rows[i]["email"]</td>
                                        <td>@dtl.Rows[i]["mobile"]</td>
                                        <td>@dtl.Rows[i]["password"]</td>
                                        <td>@dtl.Rows[i]["dob"]</td>
                                        <td>@dtl.Rows[i]["gender"]</td>
                                        <td>@dtl.Rows[i]["picture"]</td>
                                        <td>@dtl.Rows[i]["rdate"]</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No Records Found Here</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>