@{
    ViewBag.Title = "ComplainResponse";
    Layout = "~/Views/Shared/AdminZone.cshtml";
}

@using System.Data;
@using System.Data.SqlClient;
@using ArcaneClinic.Models;
<div class="row">
    <div class="col-4"></div>
    <div class="col-4" style="box-shadow:2px 2px 12px 2px rosybrown; padding:2%;">
        <h2>Complain Response</h2>
        <hr />
        <form action="/Admin/ComplainResponse" method="post">
            <label>Complain id</label>
            <input type="text" value="@ViewBag.id" name="txtid" class="form-control" readonly />
            <label>UserId</label>
            <input type="text" value="@ViewBag.user" name="txtuid" class="form-control" readonly />
            <label>Response Message</label>
            <textarea class="form-control" name="txtmsg" required></textarea>
            <br />
            <input type="submit" value="Response Now" class="form-control btn btn-dark" />
            <h4 class="text-success">@ViewBag.msg</h4>
        </form>
    </div>
    <div class="col-4"></div>
</div>
<br />
<hr />
<br />
<div class="container" style="box-shadow:5px 5px 10px 5px gray; margin-top:2%;">
    <div class="row">
        <div class="col-12">
            <br />
            <h2 class="text-center text-capitalize" style="color:rosybrown; font-weight:bolder;"> Complain Response Panel</h2>
            Searchbar: <input type="text" id="txtsearch" placeholder="Enter keyword" />
            <hr />
        </div>

        <!-- Responsive Table -->
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead>
                        <tr>
                            <th>SN</th>
                            <th>COMPLAIN.ID</th>
                            <th>USER ID</th>
                            <th>RESPONSE</th>
                            <th>RESPONSE DATE</th>
                        </tr>
                    </thead>
                    <tbody id="tblsearch">
                        @{
                            string cmd = "select * from ComplainResponse";
                            DataTable dt = DatabaseManager.Display_All_Records(cmd);
                            if (dt.Rows.Count > 0)
                            {
                                for (int i = 0; i < dt.Rows.Count; i++)
                                {
                                    <tr>
                                        <td>@dt.Rows[i]["crid"]</td>
                                        <td>@dt.Rows[i]["cmp_id"]</td>
                                        <td>@dt.Rows[i]["userid"]</td>
                                        <td>@dt.Rows[i]["rcmp_msg"]</td>
                                        <td>@dt.Rows[i]["crdate"]</td>
                                        
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No Records Found Here</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $("#txtsearch").keyup(function () {
            var value = $(this).val().toLowerCase();
            $("#tblsearch tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
            })
        })
    })
</script>


