<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100..900&family=Roboto:ital,wght@0,100;0,300;0,700;1,100;1,300&display=swap" rel="stylesheet">
    <link href="~/Content/Style.css" rel="stylesheet" />

    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/jquery-1.8.2.min.js"></script>
    <style>
        .hover-effect {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .hover-effect:hover {
                transform: scale(1.0);
                box-shadow: 0 4px 20px #548235;
            }

            .hover-effect img {
                transition: transform 0.3s ease;
            }

            .hover-effect:hover img {
                transform: scale(1.1);
            }
        body {
            font-family: "Roboto Slab", serif;
            font-optical-sizing: auto;
            font-weight: 400;
            font-style: normal;
        }
        .nav-item{
            color: #004E9A;
        }
    </style>

</head>
@using System.Data;
@using System.Data.SqlClient;
@using ArcaneClinic.Models;
<body>
    <!-- Navbar -->
    <div class="container-fluid fixed-top">
        <div class="row">
            <nav class="navbar navbar-expand-lg bg-light" style="background: white; box-shadow: 0px 3px 5px 0px #004E9A; ">
                <div class="container">
                    @{
                        string query = "select * from AddLogo";
                        DataTable dt = DatabaseManager.Display_All_Records(query);
                        if (dt.Rows.Count > 0)
                        {
                            <img src="~/Content/Slider_img/@dt.Rows[0]["logopic"]" style="height:70px" width="200px" alt="LOGO">
                        }
                    }
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                            data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false"
                            aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav  m-auto" style="margin-right: 600px; font-size: large; font-weight: bold;">
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/Index" style="color: #004E9A">DashBoard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/MyProfile" style="color: #004E9A">My Profile</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle hover-effect bold" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: #004E9A">
                                    Appointment
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item hover-effect" href="/Patient/Appointment" style="color: #004E9A">Book Appointment</a></li>
                                    <li><a class="dropdown-item hover-effect" href="/Patient/ViewAppointment" style="color: #004E9A">View Appointments</a></li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/ViewNotification" style="color: #004E9A">Notifications</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/ViewResponse" style="color: #004E9A">View Response</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/Complain" style="color: #004E9A">Complain</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/Feedback" style="color: #004E9A">Feedback</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/ChangePassword" style="color: #004E9A">Change Password</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active hover-effect" href="/Patient/LogOut" style="color: #004E9A">Logout</a>
                            </li>
                        </ul>

                    </div>
                </div>
            </nav>
        </div>
    </div>
    <br />
    <br />
    <div class="mt-5">
        @RenderBody()
    </div>
    <br />
    <!-- Footer -->
    <footer class="bg-dark text-white pt-4 border-top fs-4" .>
        <div class="container-fluid">
            <div class="row">
                <!-- About Section -->
                <div class="col-md-1"></div>
                <div class="col-md-3">
                    <h5 class="fw-bold text-uppercase">About Delight M S Hospital</h5><br />
                    <p class="small">
                        Delight Multi-Speciality Hospital provides premier healthcare services, blending innovation and care to ensure the best outcomes for our patients.
                    </p>
                </div>

                <!-- Quick Links -->
                <div class="col-md-2">
                    <h5 class="fw-bold text-uppercase">Quick Links</h5><br />
                    <ul class="list-unstyled small">
                        <li><a href="/Home/Index" class="text-decoration-none" style="font-weight:bold;color:">Home</a></li>
                        <li><a href="/Home/AboutUs" class="text-decoration-none">About Us</a></li>
                        <li><a href="/Home/OurDoctor" class="text-decoration-none">Our Doctors</a></li>
                        <li><a href="/Home/Contact" class="text-decoration-none">Contact Us</a></li>
                        <li><a href="/Home/JoinUs" class="text-decoration-none">Join us</a></li>
                    </ul>
                </div>

                <!-- Patient Services -->
                <div class="col-md-2">
                    <h5 class="fw-bold text-uppercase">Patient Services</h5><br />
                    <ul class="list-unstyled small">
                        <li><a href="/Home/Login" class="text-decoration-none">Book Appointment</a></li>
                        <li><a href="/Home/Login" class="text-decoration-none">Medical Records</a></li>
                        <li><a href="/Home/Login" class="text-decoration-none">Health Packages</a></li>
                        <li><a href="/Home/Login" class="text-decoration-none">Notifications</a></li>
                        <li><a href="/Home/Login" class="text-decoration-none">FAQs</a></li>
                    </ul>
                </div>

                <!-- Contact Information -->
                <div class="col-md-3">
                    <h5 class="fw-bold text-uppercase">Contact Us</h5><br />
                    <p class="small">
                        <i class="bi bi-geo-alt-fill"></i> Gudamba, Dh2, Sport collage, 36, Kursi Rd, Lucknow, Gudamba, Uttar Pradesh 226026<br>
                        <i class="bi bi-telephone-fill"></i>
                        <a href="tel:+919026663765" class="text-decoration-none">
                            +91 9026663765
                        </a><br>
                        <i class="bi bi-phone-fill"></i>
                        <a href="tel:+918177002763" class="text-decoration-none">
                            +91 8177002763
                        </a>
                        <br>
                        <i class="bi bi-envelope-fill"></i> support@dmshospital.com
                    </p>
                </div>
                <div class="col-md-1"></div>
            </div><hr />

            <!-- Footer Bottom -->
            <div class="  row mt-3">
                <div class="col-12 text-center">
                    <p class="small mb-0" style="font-size:16px;">&copy; 2025 Copyright<a href="https://www.techwithmd.in/" style="text-decoration:none">Techwithmd  Solutions Pvt.Ltd.</a>  All rights reserved.</p>
                    <p class="small mb-0" style="font-size:16px;">Terms & Conditions | Privacy Policy</p>
                    <br />
                </div>
            </div>
        </div>
    </footer>
</body>
</html>
