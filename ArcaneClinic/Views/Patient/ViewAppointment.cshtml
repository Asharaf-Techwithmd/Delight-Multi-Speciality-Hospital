@{
    ViewBag.Title = "ViewAppointment";
    Layout = "~/Views/Shared/PatientZone.cshtml";
}
@using System.Data;
@using System.Data.SqlClient;
@using ArcaneClinic.Models;

<div class="container" style="box-shadow:5px 5px 10px 5px gray; margin-top:2%;">
    <div class="row">
        <div class="col-12">
            <br />
            <h2 class="text-center" style="color: darkorange; font-weight: bolder; color: #004E9A"> Upcoming Appointments</h2>
            <hr />
        </div>

        <!-- Responsive Table -->
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead>
                        <tr>
                            <th>S.NO</th>
                            <th>Selected Doctor</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Age (in Years)</th>
                            <th>Number</th>
                            <td> Schedule Date</td>
                            <td>Time</td>

                            
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            string id = Session["uid"] + "";
                            if (id != "" && id != null)
                           {
                               string query = "select * from Appointment where status='yes' and email='" + id + "'";
                            DataTable dtl = DatabaseManager.Display_All_Records(query);
                            if (dtl.Rows.Count > 0)
                            {                             
                                    <tr>
                                        <td>@dtl.Rows[0]["aid"]</td>
                                        <td>@dtl.Rows[0]["sdoctor"]</td>
                                        <td>@dtl.Rows[0]["name"]</td>
                                        <td>@dtl.Rows[0]["email"]</td>
                                        <td>@dtl.Rows[0]["age"] Years</td>
                                        <td>@dtl.Rows[0]["number"]</td>
                                        <td>@dtl.Rows[0]["date"]</td>
                                        <td>@dtl.Rows[0]["time"]</td>
                                        
                                    </tr>                                
                            }
                            }
                            else
                            {
                                Response.Redirect("/Home/Login");
                            }
                                                       
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<br />
<br />
<hr />

<div class="container" style="box-shadow:5px 5px 10px 5px gray; margin-top:2%;">
    <div class="row">
        <div class="col-12">
            <br />
            <h2 class="text-center" style="color: darkorange; font-weight: bolder; color: #004E9A"> Past Appointments Records</h2>
            <hr />
        </div>

        <!-- Responsive Table -->
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead>
                        <tr>
                            <th>S.NO</th>
                            <th>Selected Doctor</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Age (in Years)</th>
                            <th>Number</th>
                            <td>Schedule Date</td>
                            <td>Time</td>

                        </tr>
                    </thead>
                    <tbody>
                        @{
                            string ed = Session["uid"] + "";
                            if (ed != "" && ed != null)
                           {
                            string cmd = "select * from Appointment where status='no' and email='"+ed+"'";
                            DataTable dt = DatabaseManager.Display_All_Records(cmd);
                            if (dt.Rows.Count > 0)
                            {
                                
                                    <tr>
                                        <td>@dt.Rows[0]["aid"]</td>
                                        <td>@dt.Rows[0]["sdoctor"]</td>
                                        <td>@dt.Rows[0]["name"]</td>
                                        <td>@dt.Rows[0]["email"]</td>
                                        <td>@dt.Rows[0]["age"] Years</td>
                                        <td>@dt.Rows[0]["number"]</td>
                                        <td>@dt.Rows[0]["date"]</td>
                                        <td>@dt.Rows[0]["time"]</td>

                                    </tr>
                                }
                            
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No Records Found Here</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


