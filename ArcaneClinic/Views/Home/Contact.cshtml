@model ArcaneClinic.Models.Contact
@{
    ViewBag.Title = "Contact";
    Layout = "~/Views/Shared/HomeZone.cshtml";
}
<style>
    .mon {
        height: 45px;
        margin-top: 3.1%;
        border-radius: 2%;
    }

    .btn-warning {
        width: 100%;
        margin-top: 1%;
        
    }
    h5 {
        color: #004E9A;
    }
   
</style>
<div class="container py-5">
    <div class="row text-center">
        <div class="col-12 col-md-4 mb-4 ">
            <div class="border p-3 rounded shadow-sm bg-light-subtle">
                <img src="~/Content/Image/phone.png" alt="Phone Icon" class="mb-3" style="max-width: 50px;">
                <h5 class="fw-bolder">Phone/Fax</h5>
                <p ><a href="tel:+919026663765" class="mb-0 fw-bold text-dark text-decoration-none " style="color: #004E9A">+91 9026663765</a></p>
                <a href="tel:+918177002763" class="fw-bold text-dark text-decoration-none " style="color: #004E9A">+91 8177002763</a>
            </div>
        </div>
        <div class="col-12 col-md-4 mb-4 ">
            <div class="border p-3 rounded shadow-sm bg-light-subtle">
                <img src="~/Content/Image/address.png" alt="Address Icon" class="mb-3" style="max-width: 50px;">
                <h5 class="fw-bolder">Address</h5>
                <p  style="color: black">Gudamba, Dh2, Sport collage, 36, Kursi Rd, Lucknow, Gudamba, Uttar Pradesh 226026</p>
            </div>
        </div>
        <div class="col-12 col-md-4 mb-4">
            <div class="border p-3 rounded shadow-sm bg-light-subtle">
                <img src="~/Content/Image/mail.png" alt="Mail Icon" class="mb-3" style="max-width: 50px;">
                <h5 class="fw-bolder">E-mail</h5>
                <p class="mb-0 fw-bold text-dark"><a href="mailto:principal@mpslucknow.in">mpslucknow.in</a></p>
                <p class="fw-bold"><a href="mailto:ceo@mpslucknow.in">ceo@mpslucknow.in</a></p>
            </div>
        </div>
    </div>
</div>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-10 col-md-8 col-lg-6" style="margin-top:2%; box-shadow: 5px 5px 12px 5px gray; padding:2%;">
            <h3 class="fw-bolder" style="font-family: Algerian; color: #004E9A">Enquiry Here</h3><h6 class="text-end">Enquiry Timing  :  10:00 AM TO 10:00 PM</h6>
            <hr style="height:3px; background:forestgreen" />

            @using (Html.BeginForm("Contact", "Home", FormMethod.Post))
            {
                <div class="row">
                    <div class="col-10 col-md-6">
                        @Html.LabelFor(model => model.Name)
                        @Html.TextBoxFor(model => model.Name, new { @class = "form-control mon", Autocomplete = "off" })
                        @Html.ValidationMessageFor(model => Model.Name, "", new { Style = "color:red" })
                        <br />

                        @Html.LabelFor(model => model.Email)
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control mon", Autocomplete = "off", type = "email" })
                        @Html.ValidationMessageFor(model => Model.Email, "", new { Style = "color:red" })
                        <br />

                        @Html.LabelFor(model => model.Mobile)
                        @Html.TextBoxFor(model => model.Mobile, new { @class = "form-control mon", Autocomplete = "off", type = "" })
                        @Html.ValidationMessageFor(model => Model.Mobile, "", new { Style = "color:red" })
                    </div>

                    <div class="col-10 col-md-6">
                
                        @Html.LabelFor(model => model.SelectedType, "Enquiry Type")
                        @Html.DropDownListFor(model => model.SelectedType, Model.TypeList, "---Select Enquiry type---", new { @class = "form-control mon" })
                        @Html.ValidationMessageFor(model => model.SelectedType, "", new { style = "color:red;" })
                        <br />
                        @Html.LabelFor(model => model.Message)
                        @Html.TextAreaFor(model => model.Message, new { @class = "form-control mon",style="min-height:75px", Autocomplete = "off" })
                        @Html.ValidationMessageFor(model => Model.Message, "", new { Style = "color:red" })
                        <br />

                        <input type="submit" class="form-control btn btn-warning mon" style="background: #004E9A;color:#fff" value="Enquiry Now" />
                    </div>
                </div>
            }

            <!-- Success Message -->
            <h4 class="btn btn-info text-bg-light hide" style="background:#007acc">@ViewBag.msg</h4>
        </div>
    </div>
</div>
<br />
<div class="container-fluid">
<div class="row">
    <div class="col-12">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3557.005835496415!2d80.97348877522519!3d26.935029476633808!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x399957296a93cf61%3A0x4bd55629ab4364e7!2sDelight%20Multi%20Speciality%20Hospital!5e0!3m2!1sen!2sin!4v1735279220011!5m2!1sen!2sin" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
</div>
    </div>
<script>
    $(document).ready(function () {
        $(".hide").fadeOut(5000);
    })
</script>

