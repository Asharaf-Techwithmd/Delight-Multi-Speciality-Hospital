@{
    ViewBag.Title = "AboutUs";
    Layout = "~/Views/Shared/HomeZone.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

<style>
.vision {
            background-color: #e6f7ff;
            padding: 50px;
            border-radius: 10px;
            margin-top: 20px;
        }
    .about-section {
        padding: 50px 0;
    }
    .quote-box {
        background-color: #e6f7ff;
        padding: 20px;
        border-radius: 10px;
        text-align: center;
        font-style: italic;
        font-weight: bold;
        margin-top: 20px;
    }
    .button {
        border: none;
        background: #004E9A;
        color:#fff;
    }
    </style>
<div class="container">
    <div class="row fs-5 text-center" style="background-image: url('/Content/Image/sl3.jpg'); background-size: cover; margin-bottom: 20px; height:400px; opacity:0.6;">
        <h1 style="color: black; font-weight: bolder; font-family: Algerian; text-align: center; margin: 100px 0px 100px 0px; ">
            ABOUT <font color="#004E9A">US</font>
        </h1>
    </div>

    <div class="container-fluid">
        <div class="quote-box mt-4">
            "We at DELIGHT are COMMITTED to providing exceptional healthcare services through continuous innovation, expertise, and a patient-first approach for complete customer satisfaction."
        </div>
        <br />
        <div class="row">
            <div class="col-sm-4">
                <div class="card-group hover-effect">
                    <div class="card">
                        <div class="card-body text-center text-dark ">
                            <h5 class="card-title" style="color: #004E9A;"><span><i class="fas fa-stethoscope"></i></span>Treatment</h5>
                            <p>The use of medicine or medical care to cure an illness or injury; something that is done to make somebody feel and look good.</p>
                            <a href="/Home/Login" class="btn btn-outline-info button"  type="submit">Appointment</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card-group hover-effect">
                    <div class="card">
                        <div class="card-body text-center text-dark ">
                            <h5 class="card-title" style="color: #004E9A;"><span><i class="fas fa-phone"></i></span>Emergency Help</h5>
                            <p>Aid provided in the event of a situation that creates an imminent risk of serious harm to the health or safety of the person</p>
                            <a href="/Home/Contact" class="btn btn-outline-info button" type="submit">To Help</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="card-group hover-effect">
                    <div class="card">
                        <div class="card-body text-center text-dark ">
                            <h5 class="card-title" style="color: #004E9A;"><span><i class="fas fa-staff-snake"></i></span>Medical Staff</h5>
                            <p>Doctors access and manage your medical treatment. Allied health professionals provide services to help with treatment</p>
                            <a href="/Home/OurDoctor" class="btn btn-outline-info button" type="submit">Medical Staff</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <br />
    <div class="container about-section">
        <div class="row">
            <div class="col-md-6">
         
                <img src="~/Content/Image/sl1.jpg"  class="img-thumbnail img-responsive" />
            </div>
            <div class="col-md-6">
                <h2 style="color: #004E9A;font-weight:bold;font-family:Cambria">Who We Are</h2>
                <p>
                    Delight Multi-Specialty Hospital is a premier healthcare institution committed to providing advanced medical care with compassion and precision. With state-of-the-art facilities and a team of dedicated professionals, we strive to redefine healthcare standards.
                </p>
                <p>
                    Established with a vision to serve the community, Delight Hospital offers comprehensive medical services across various specialties. Our mission is to ensure that every patient receives personalized, high-quality care in a supportive and comfortable environment.
                </p>
                <p>Modern infrastructure equipped with advanced medical technology for accurate diagnoses and effective treatments.</p>
                <p>A team of experienced doctors, surgeons, and healthcare professionals committed to patient care and well-being.</p>
                <p>We prioritize patient satisfaction and comfort, ensuring a holistic approach to healing and recovery.</p>
                <p>We create a supportive and comfortable environment to make your healthcare journey stress-free and effective.</p>
            </div>
        </div>
    </div>
    <br />
    <h2 class="text-center" style="color: #004E9A;font-family:Cambria;font-weight:bold;">Our Vision & Mission</h2>

    <div class="container vision">
        <div class="row">
            <div class="col-md-6">
                <h4>Our Vision</h4>
                <p>
                    To become a leading healthcare institution recognized for excellence in patient care, innovation, and community service.
                </p>
                <p>
                    To be a beacon of hope and healing, setting new standards of excellence in healthcare while fostering a compassionate, patient-centered environment that empowers individuals and communities to achieve their best health.
                </p>
            </div>
            <div class="col-md-6">
                <h4>Our Mission</h4>
                <p>
                    To provide world-class healthcare services with compassion, precision, and a patient-centered approach, fostering trust and reliability within our community.
                </p>
                <p>
                    Ensure every patient feels respected, cared for, and supported through personalized care and empathy.
                </p>
                <p> Operate with a commitment to environmental and social responsibility for a healthier future.</p>
            </div>
        </div>
    </div>
    <br /><br />
    <div class="row">
        <h2 style="font-weight: bolder; text-align: center; font-family: Algerian; color: #004E9A">Why Choose Us?</h2>
        <p style="text-align:center;">Remember, the choice of a hospital should also consider factors like location, insurance coverage, and the specific medical needs of the patient. It’s important to conduct thorough research, read patient reviews, and consult with your primary care physician or specialists before making a decision.</p>
    </div>
    <br /><br />
    <div class="row mb-3">
        <div class="col-sm-4" style="padding:27px;">
            <div class="card-group hover-effect">
                <div class="card">
                    <div class="card-body text-center text-dark ">
                        <h3 style="color: #004E9A; text-align: justify;"><span><i class="fas fa-notes-medical"></i></span> Professional</h3>
                        <p>The doctor must be committed to observing fairness, honesty, correctness in his interactions with patients.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card-group hover-effect">
                <div class="card">
                    <div class="card-body text-center text-dark ">
                        <img src="~/Content/image/p1.jpg" style=" text-align: justify; height: 200px; width: 100%;" />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4" style="padding:27px;">
            <div class="card-group hover-effect">
                <div class="card">
                    <div class="card-body text-center text-dark ">
                        <h3 style="color: #004E9A; text-align: justify;"><span><i class="fas fa-pills"></i></span> Professional</h3>
                        <p>Professionalism is not a new concept and has existed throughout the history of medicine in the form of medical oaths.</p>
                    </div>
                </div>
            </div>
        </div>


    </div>
</div>
